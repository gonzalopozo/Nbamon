{
    "name": "nbamon",
    "version": "1.0.0",
    "description": "Online multiplayer NBA-themed game inspired by Pokemon. Players choose NBA characters, move on a canvas map, and battle in rock-paper-scissors style combat (MATE > PASE > TAPÓN > MATE) best of 5 rounds. Built with Express 5, Vanilla JS, and Canvas API.",
    "keywords": [
        "nba",
        "game",
        "multiplayer",
        "online",
        "canvas",
        "express",
        "pokemon",
        "combat",
        "vanilla-js"
    ],
    "license": "UNLICENSED",
    "author": "Gonzalo Pozo (https://github.com/gonzalopozo)",
    "main": "index.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/gonzalopozo/Nbamon"
    },
    "scripts": {
        "audit": "pnpm audit",
        "audit:fix": "pnpm audit --fix",
        "check-updates": "pnpm dlx npm-check-updates",
        "depcruise": "depcruise . --validate",
        "depcruise:graph": "depcruise . --output-type mermaid > dependency-graph.md",
        "depcruise:graph:svg": "depcruise . --output-type dot | dot -T svg > dependency-graph.svg",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "knip": "knip",
        "knip:fix": "knip --fix --format",
        "knip:production": "knip --production",
        "lint": "eslint .",
        "lint:css": "stylelint \"**/*.css\"",
        "lint:css:fix": "stylelint \"**/*.css\" --fix",
        "lint:fix": "eslint . --fix",
        "lint:html": "html-validate public/index.html",
        "lint:package": "npmPkgJsonLint .",
        "prepare": "husky",
        "spell": "cspell .",
        "spell:fix": "cspell . --no-progress --no-summary -u",
        "start": "node ./index.js",
        "test": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:report": "playwright show-report",
        "test:e2e:ui": "playwright test --ui",
        "update:latest": "pnpm up --latest"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "i18next": "^25.10.6",
        "i18next-http-backend": "^3.0.2"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@cspell/dict-es-es": "^3.0.8",
        "@cspell/dict-it-it": "^3.1.6",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.5.0",
        "axe-core": "^4.11.1",
        "cspell": "^9.7.0",
        "dependency-cruiser": "^17.3.9",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "html-validate": "^10.11.2",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "knip": "^6.0.5",
        "lint-staged": "^16.4.0",
        "npm-package-json-lint": "^9.1.0",
        "npm-package-json-lint-config-default": "^8.0.1",
        "prettier": "^3.8.1",
        "stylelint": "^17.5.0",
        "stylelint-config-standard": "^40.0.0",
        "vitest": "^4.1.1"
    },
    "engines": {
        "node": ">=20"
    },
    "lint-staged": {
        "*.{js,mjs,cjs}": [
            "eslint --fix",
            "prettier --write",
            "cspell --no-progress --no-summary"
        ],
        "*.css": [
            "stylelint --fix",
            "prettier --write",
            "cspell --no-progress --no-summary"
        ],
        "*.html": [
            "prettier --write",
            "html-validate",
            "cspell --no-progress --no-summary"
        ],
        "*.{json,md}": [
            "prettier --write",
            "cspell --no-progress --no-summary"
        ],
        "package.json": [
            "prettier --write",
            "cspell --no-progress --no-summary",
            "npmPkgJsonLint"
        ]
    }
}
